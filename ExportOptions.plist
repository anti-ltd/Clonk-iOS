<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Store Connect distribution for the Clink container app + its two
	     embedded keyboard extensions. Automatic signing: xcodebuild creates the
	     Apple Distribution cert + App Store profiles on demand when invoked with
	     -allowProvisioningUpdates and the ASC API key (see `make upload-asc`). -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>export</string>
	<key>teamID</key>
	<string>8248296AJX</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>uploadSymbols</key>
	<true/>
	<!-- Keep the build number we set in the Info.plists; don't let Xcode rewrite it. -->
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
</dict>
</plist>
